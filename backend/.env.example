# Backend Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/elite-chat
MONGODB_USERNAME=
MONGODB_PASSWORD=

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:19000

# File Upload
MAX_FILE_SIZE=50000000
UPLOAD_DIR=./uploads

# WebSocket
WEBSOCKET_URL=ws://localhost:5000

# Email (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Media (for video calls - optional)
JITSI_URL=https://meet.jit.si